{
  "manifest_version": 3,
  "name": "文章 Markdown 下载器",
  "version": "0.1.0",
  "description": "下载微信公众号与知乎专栏文章为 Markdown 和本地图片资源。",
  "permissions": ["activeTab", "downloads", "storage"],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "https://mmbiz.qpic.cn/*",
    "https://zhuanlan.zhihu.com/*",
    "https://picx.zhimg.com/*",
    "https://pica.zhimg.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mp.weixin.qq.com/*",
        "https://zhuanlan.zhihu.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
