{
  "name": "markdown-downloader",
  "private": false,
  "version": "0.1.0",
  "description": "Chrome MV3 extension for downloading WeChat and Zhihu articles as Markdown with local images.",
  "type": "module",
  "author": "Siyuan Li",
  "license": "MIT",
  "homepage": "https://github.com/Cyronlee/markdown-downloader",
  "bugs": {
    "url": "https://github.com/Cyronlee/markdown-downloader/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyronlee/markdown-downloader.git"
  },
  "keywords": [
    "chrome-extension",
    "markdown",
    "wechat",
    "weixin",
    "mv3",
    "zhihu"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --config vite.popup.config.ts",
    "build": "tsc -p tsconfig.json && vite build --config vite.popup.config.ts && vite build --config vite.content.config.ts",
    "preview": "vite preview --config vite.popup.config.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.4.0",
    "@types/turndown": "^5.0.6",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
